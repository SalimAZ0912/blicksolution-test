<div class="cpp-features">
  {%- for i in (1..3) -%}
    {%- assign title_key = 'feature_title_' | append: i -%}
    {%- assign text_key  = 'feature_text_'  | append: i -%}
    <div class="cpp-feature-item">
      <div class="cpp-feature-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="9" r="6"/>
          <path d="M9 9l1.5 1.5L15 7.5"/>
          <path d="M8.5 14.5L7 23l5-2.5 5 2.5-1.5-8.5"/>
        </svg>
      </div>
      <div class="cpp-feature-text">
        <strong>{{ section.settings[title_key] | default: '100% Qualität' }}</strong>
        <span>{{ section.settings[text_key] | default: 'Dank weichem Silikon' }}</span>
      </div>
    </div>
  {%- endfor -%}
</div>

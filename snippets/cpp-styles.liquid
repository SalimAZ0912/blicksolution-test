<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  .cpp-wrapper,
  .cpp-features {
    font-family: 'Montserrat', sans-serif;
  }

  .cpp-outer {
    max-width: fit-content;
    margin: var(--cpp-spacing-top, 48px) auto 48px;
    padding: 0 24px;
  }

  .cpp-wrapper {
    display: grid;
    grid-template-columns: 1fr 475px;
    gap: 50px;
    align-items: center;
  }

  .cpp-gallery-col {
    display: grid;
    grid-template-columns: 100px 480px;
    column-gap: 18px;
  }

  .cpp-gallery {
    display: contents;
  }

  .cpp-thumbs {
    align-self: center;
  }

  .cpp-arrows {
    grid-column: 2;
  }

  .cpp-thumbs {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cpp-thumb {
    width: 100px;
    height: 100px;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s ease;
    background: #f5f5f5;
  }

  .cpp-thumb.is-active {
    display: none;
  }

  .cpp-thumb:hover {
    border-color: var(--cpp-accent, #1f47ff);
  }

  .cpp-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cpp-main-wrap {
    width: 480px;
  }

  .cpp-main-img {
    border-radius: 5px;
    background: #f3f3f3;
    width: 480px;
    height: 480px;
    display: flex;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }

  .cpp-main-img::-webkit-scrollbar {
    display: none;
  }

  .cpp-main-img img {
    flex-shrink: 0;
    width: 480px;
    height: 480px;
    object-fit: cover;
    display: block;
    scroll-snap-align: start;
  }

  .cpp-dots {
    display: none;
    justify-content: center;
    gap: 8px;
    margin-top: 12px;
  }

  .cpp-dot-bullet {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #f8f8f8;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s;
  }

  .cpp-dot-bullet.is-active {
    background: #e5e5e5;
    box-shadow: inset 0 3px 4px 0 #00000029;
  }

  .cpp-arrows {
    display: flex;
    justify-content: center;
    gap: 10px;
  }

  .cpp-arrow {
    background: none;
    border: none;
    cursor: pointer;
    outline: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 5px;
  }

  .cpp-arrow img {
    width: 15px;
    height: 15px;
    display: block;
  }

  .cpp-prev img {
    transform: scaleX(-1);
  }

  .cpp-arrow:disabled img {
    opacity: 0.25;
  }

  .cpp-arrow:disabled {
    cursor: default;
  }

  .cpp-info-card {
    width: 100%;
    background: var(--cpp-card-bg, #ffffff);
    box-shadow: var(--cpp-card-shadow, 0px 3px 20px #00000029);
    border: 1px solid var(--cpp-card-border, #d5d5d5);
    border-radius: var(--cpp-card-radius, 5px);
    padding: 18px 28px;
    display: flex;
    flex-direction: column;
  }

  .cpp-product-title {
    margin-bottom: 12px;
    font: normal normal 600 25px/30px Montserrat;
    letter-spacing: 0px;
    color: #000000;
  }

  .cpp-product-type {
    text-align: left;
    font: normal normal 500 18px/22px Montserrat;
    letter-spacing: 0px;
    color: #000000;
    margin-top: 0;
  }

  .cpp-price {
    display: flex;
    align-items: baseline;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }

  .cpp-price-compare {
    text-align: left;
    text-decoration: line-through;
    font: normal normal 600 18px/22px Montserrat;
    letter-spacing: 0px;
    color: #000000;
    margin-right: 20px;
  }

  .cpp-price-sale {
    text-align: left;
    font: normal normal 600 18px/22px Montserrat;
    letter-spacing: 0px;
    color: var(--cpp-accent, #1f47ff);
    margin-right: 6px;
  }

  .cpp-price-tax {
    text-align: left;
    font: normal normal 500 10px/13px Montserrat;
    letter-spacing: 0px;
    color: #000000;
  }

  .cpp-availability {
    text-align: left;
    font: normal normal 500 15px/19px Montserrat;
    letter-spacing: 0px;
    color: #25a525;
    margin-bottom: 37px;
    display: flex;
    align-items: center;
  }

  .cpp-dot {
    width: 15px;
    height: 15px;
    border-radius: 50%;
    display: inline-block;
    margin-right: 10px;
  }

  .cpp-dot--green {
    background: #25a525;
  }

  .cpp-dot--red {
    background: #dc2626;
  }

  .cpp-atc-btn {
    font: normal normal 600 18px/22px Montserrat;
    color: var(--cpp-btn-text, #ffffff);
    width: 424px;
    height: 52px;
    background: var(--cpp-accent, #1f47ff);
    border-radius: 3px;
    border: none;
  }

  .cpp-atc-btn:hover {
    filter: brightness(0.88);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  .cpp-atc-btn:active {
    transform: scale(0.98);
  }

  .cpp-atc-btn:disabled {
    background: #9ca3af;
    cursor: not-allowed;
    box-shadow: none;
  }

  .cpp-atc-btn.added {
    background: #16a34a;
  }

  .cpp-features {
    display: flex;
    margin-top: 37px;
    gap: 32px;
    justify-content: space-between;
  }

  .cpp-feature-item {
    display: flex;
    align-items: center;
    gap: 17px;
  }

  .cpp-feature-icon {
    flex-shrink: 0;
    color: #333;
    width: 57px;
    height: 57px;
  }

  .cpp-feature-icon img,
  .cpp-feature-icon svg {
    display: block;
  }

  .cpp-feature-text {
    display: flex;
    flex-direction: column;
  }

  .cpp-feature-text strong {
    text-align: left;
    font: normal normal 500 18px/22px Montserrat;
    letter-spacing: 0px;
    margin-bottom: 5px;
    color: #000000;
  }

  .cpp-feature-text span {
    text-align: left;
    font: normal normal normal 18px/22px Montserrat;
    letter-spacing: 0px;
    color: #383838;
  }

  @media (max-width: 959px) {
    .cpp-outer {
      width: 100%;
      max-width: 100%;
      padding: 0 16px;
      margin: 24px auto;
      box-sizing: border-box;
    }

    .cpp-wrapper {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .cpp-info-card {
      padding: 26px 14px;
    }

    .cpp-gallery-col {
      display: block;
    }

    .cpp-gallery {
      display: flex;
      flex-direction: column-reverse;
      gap: 12px;
    }

    .cpp-thumbs {
      display: none;
    }

    .cpp-main-wrap {
      width: 100%;
    }

    .cpp-main-img {
      width: 100%;
      height: auto;
    }

    .cpp-main-img img {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
      margin: 0;
    }

    .cpp-dots {
      display: flex;
    }

    .cpp-arrows {
      display: none;
    }

    .cpp-atc-btn {
      width: 100%;
    }

    .cpp-features {
      flex-direction: column;
      gap: 20px;
      margin-top: 37px;
      align-items: center;
    }

    .cpp-feature-text strong {
      font-size: 16px;
    }

    .cpp-feature-text span {
      font-size: 16px;
    }

    .cpp-feature-icon {
      width: 48px;
      height: 48px;
    }
  }
</style>

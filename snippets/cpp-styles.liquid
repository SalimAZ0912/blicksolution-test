<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  .cpp-wrapper,
  .cpp-features {
    font-family: 'Montserrat', sans-serif;
  }

  .cpp-outer {
    max-width: fit-content;
    margin: 48px auto;
    padding: 0 24px;
  }

  .cpp-wrapper {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 50px;
    align-items: center;
  }

  /* ── GALLERY (Thumbs + Hauptbild) ── */
  .cpp-gallery {
    display: flex;
    flex-direction: row;
    gap: 18px;
    align-items: flex-start;
    align-items: center;
  }

  /* ── THUMBNAILS ── */
  .cpp-thumbs {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cpp-thumb {
    width: 100px;
    height: 100px;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s ease;
    background: #f5f5f5;
  }

  .cpp-thumb.is-active {
    display: none;
  }

  .cpp-thumb:hover {
    border-color: #2563eb;
  }

  .cpp-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── MAIN IMAGE ── */
  .cpp-main-wrap {
    width: 480px;
  }

  .cpp-main-img {
    border-radius: 5px;
    background: #f3f3f3;
    width: 480px;
    height: 480px;
    display: flex;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }

  .cpp-main-img::-webkit-scrollbar {
    display: none;
  }

  .cpp-main-img img {
    flex-shrink: 0;
    width: 480px;
    height: 480px;
    object-fit: cover;
    display: block;
    scroll-snap-align: start;
  }

  /* ── DOTS ── */
  .cpp-dots {
    display: none;
    justify-content: center;
    gap: 8px;
    margin-top: 12px;
  }

  .cpp-dot-bullet {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ccc;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s;
  }

  .cpp-dot-bullet.is-active {
    background: #111;
  }

  .cpp-arrows {
    display: flex;
    justify-content: center;
    gap: 16px;
  }

  .cpp-arrow {
    background: none;
    border: none;
    cursor: pointer;
    outline: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 10px;
  }

  .cpp-arrow img {
    width: 15px;
    height: 15px;
    display: block;
  }

  .cpp-prev img {
    transform: scaleX(-1);
  }

  .cpp-arrow:disabled img {
    opacity: 0.25;
  }

  .cpp-arrow:disabled {
    cursor: default;
  }

  /* ── INFO CARD ── */
  .cpp-info-card {
    width: 100%;
    background: #ffffff 0% 0% no-repeat padding-box;
    box-shadow: 0px 3px 20px #00000029;
    border: 1px solid #d5d5d5;
    border-radius: 5px;
    padding: 18px 28px;
    display: flex;
    flex-direction: column;
  }

  .cpp-product-title {
    margin-bottom: 12px;
    font: normal normal 600 25px/30px Montserrat;
    letter-spacing: 0px;
    color: #000000;
  }

  .cpp-product-type {
    text-align: left;
    font: normal normal 500 18px/22px Montserrat;
    letter-spacing: 0px;
    color: #000000;
    margin-top: 0;
  }

  .cpp-price {
    display: flex;
    align-items: baseline;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }

  .cpp-price-compare {
    text-align: left;
    text-decoration: line-through;
    font: normal normal 600 18px/22px Montserrat;
    letter-spacing: 0px;
    color: #000000;
    margin-right: 20px;
  }

  .cpp-price-sale {
    text-align: left;
    font: normal normal 600 18px/22px Montserrat;
    letter-spacing: 0px;
    color: #1f47ff;
    margin-right: 6px;
  }

  .cpp-price-tax {
    text-align: left;
    font: normal normal 500 10px/13px Montserrat;
    letter-spacing: 0px;
    color: #000000;
  }

  .cpp-availability {
    text-align: left;
    font: normal normal 500 15px/19px Montserrat;
    letter-spacing: 0px;
    color: #25a525;
    margin-bottom: 37px;
    display: flex;
    align-items: center;
  }

  .cpp-dot {
    width: 15px;
    height: 15px;
    border-radius: 50%;
    display: inline-block;
    margin-right: 10px;
  }

  .cpp-dot--green {
    background: #25a525;
  }
  .cpp-dot--red {
    background: #dc2626;
  }

  /* ── ATC BUTTON ── */
  .cpp-atc-btn {
    font: normal normal 600 18px/22px Montserrat;
    color: #ffffff;
    width: 424px;
    height: 52px;
    background: #1f47ff;
    border-radius: 3px;
    border: none;
  }

  .cpp-atc-btn:hover {
    background: #1d4ed8;
    box-shadow: 0 4px 16px rgba(37, 99, 235, 0.35);
  }

  .cpp-atc-btn:active {
    transform: scale(0.98);
  }
  .cpp-atc-btn:disabled {
    background: #9ca3af;
    cursor: not-allowed;
    box-shadow: none;
  }

  .cpp-atc-btn.added {
    background: #16a34a;
  }

  /* ── FEATURES ── */
  .cpp-features {
    display: grid;
    grid-template-columns: auto;
    grid-auto-flow: column;
    margin-top: 40px;
    padding-top: 40px;
    justify-content: space-between;
  }

  .cpp-feature-item {
    display: flex;
    align-items: center;
    gap: 17px;
  }

  .cpp-feature-icon {
    flex-shrink: 0;
    color: #333;
  }

  .cpp-feature-icon svg {
    width: 48px;
    height: 48px;
  }

  .cpp-feature-text {
    display: flex;
    flex-direction: column;
  }

  .cpp-feature-text strong {
    text-align: left;
    font: normal normal 500 18px/22px Montserrat;
    letter-spacing: 0px;
    margin-bottom: 5px;
    color: #000000;
  }

  .cpp-feature-text span {
    text-align: left;
    font: normal normal normal 18px/22px Montserrat;
    letter-spacing: 0px;
    color: #383838;
  }

  /* ── RESPONSIVE: Mobile-first ── */

  /* Base: Mobile */
  .cpp-outer {
    width: 100%;
    max-width: 100%;
    padding: 0 16px;
    margin: 24px auto;
    box-sizing: border-box;
  }

  .cpp-atc-btn {
    width: 100%;
  }

  .cpp-wrapper {
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .cpp-gallery {
    flex-direction: column-reverse;
    gap: 12px;
  }

  .cpp-thumbs {
    display: none;
  }

  .cpp-thumb {
    min-width: 70px;
    width: 70px;
    height: 70px;
    flex-shrink: 0;
  }

  /* Slider nimmt exakt die volle Viewport-Breite ein */
  .cpp-main-wrap {
    width: 100vw;
    margin-left: -16px;
  }

  .cpp-main-img {
    width: 100vw;
    height: auto;
  }

  .cpp-main-img img {
    width: 100vw;
    height: auto;
    aspect-ratio: 1 / 1;
    scroll-snap-align: start;
    margin: 0;
  }

  .cpp-info-card {
    width: 100%;
  }

  /* Features: stack vertically on mobile */
  .cpp-features {
    grid-template-columns: 1fr;
    grid-auto-flow: row;
    gap: 20px;
  }

  /* Dots visible on mobile */
  .cpp-dots {
    display: flex;
  }

  /* Arrows hidden on mobile */
  .cpp-arrows {
    display: none;
  }

  /* Desktop: ab 960px */
  @media (min-width: 960px) {
    .cpp-outer {
      max-width: fit-content;
      width: auto;
      padding: 0 24px;
      margin: 48px auto;
    }

    .cpp-wrapper {
      grid-template-columns: 1fr 475px;
      gap: 50px;
    }

    .cpp-gallery {
      flex-direction: row;
      gap: 18px;
    }

    .cpp-thumbs {
      display: flex;
      flex-direction: column;
      overflow-x: unset;
    }

    .cpp-thumb {
      min-width: unset;
      width: 100px;
      height: 100px;
    }

    .cpp-main-wrap {
      width: 480px;
      height: 480px;
    }

    .cpp-main-img {
      width: 480px;
      height: 480px;
    }

    .cpp-main-img img {
      width: 480px;
      height: 480px;
    }

    .cpp-info-card {
      width: 100%;
    }

    .cpp-features {
      gap: 32px;
      grid-auto-flow: none;
      display: flex;
    }

    .cpp-arrows {
      display: flex;
    }

    .cpp-dots {
      display: none;
    }

    /* Touch-Targets: min 44px für Arrows */
    .cpp-arrow {
      min-width: 44px;
      min-height: 44px;
    }
  }
</style>

<form id="cpp-atc-form-{{ section_id }}" {{ block.shopify_attributes }}>
  <input type="hidden" name="id" value="{{ current_variant.id }}">
  <input type="hidden" name="quantity" value="1">
  <button type="submit"
          class="cpp-atc-btn"
          id="cpp-atc-btn-{{ section_id }}"
          style="font-size: {{ block.settings.font_size }}px; border-radius: {{ block.settings.border_radius }}px; height: {{ block.settings.button_height }}px;"
          {% unless current_variant.available %}disabled{% endunless %}>
    {{ block.settings.button_text | default: 'In den Einkaufswagen' }}
  </button>
</form>

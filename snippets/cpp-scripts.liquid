<script>
(function() {
  var sectionId = '{{ section_id }}';
  var thumbContainer = document.getElementById('cpp-thumbs-' + sectionId);
  var slider = document.getElementById('cpp-slider-' + sectionId);
  var dotsContainer = document.getElementById('cpp-dots-' + sectionId);
  var atcForm = document.getElementById('cpp-atc-form-' + sectionId);
  var atcBtn  = document.getElementById('cpp-atc-btn-'  + sectionId);

  if (!slider) return;

  var thumbs  = thumbContainer ? Array.from(thumbContainer.querySelectorAll('.cpp-thumb')) : [];
  var dots    = dotsContainer  ? Array.from(dotsContainer.querySelectorAll('.cpp-dot-bullet')) : [];
  var total   = dots.length || thumbs.length;
  var current = 0;
  var prevBtns = Array.from(document.querySelectorAll('.cpp-prev[data-section="' + sectionId + '"]'));
  var nextBtns = Array.from(document.querySelectorAll('.cpp-next[data-section="' + sectionId + '"]'));

  function updateActive(index) {
    current = index;
    thumbs.forEach(function(t, i) { t.classList.toggle('is-active', i === index); });
    dots.forEach(function(d, i) { d.classList.toggle('is-active', i === index); });
    prevBtns.forEach(function(btn) { btn.disabled = current === 0; });
    nextBtns.forEach(function(btn) { btn.disabled = current === total - 1; });
  }

  function goTo(index) {
    if (index < 0 || index >= total) return;
    slider.scrollTo({ left: index * slider.offsetWidth, behavior: 'smooth' });
    updateActive(index);
  }

  var scrollTimer;
  slider.addEventListener('scroll', function() {
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(function() {
      var index = Math.round(slider.scrollLeft / slider.offsetWidth);
      updateActive(index);
    }, 80);
  }, { passive: true });

  thumbs.forEach(function(thumb, i) {
    thumb.addEventListener('click', function() { goTo(i); });
  });

  dots.forEach(function(dot, i) {
    dot.addEventListener('click', function() { goTo(i); });
  });

  prevBtns.forEach(function(btn) {
    btn.addEventListener('click', function() { goTo(current - 1); });
  });
  nextBtns.forEach(function(btn) {
    btn.addEventListener('click', function() { goTo(current + 1); });
  });

  updateActive(0);

  if (atcForm) {
    atcForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var variantId = atcForm.querySelector('[name="id"]').value;
      atcBtn.disabled = true;
      atcBtn.textContent = 'Wird hinzugefügt...';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      })
      .then(function(res) { return res.json(); })
      .then(function() {
        return fetch('/cart.js').then(function(r) { return r.json(); });
      })
      .then(function(cart) {
        document.dispatchEvent(new CustomEvent('cart:update', { bubbles: true, detail: { resource: cart, data: {} } }));
        atcBtn.textContent = '✓ Hinzugefügt!';
        atcBtn.classList.add('added');
        setTimeout(function() {
          atcBtn.textContent = 'In den Einkaufswagen';
          atcBtn.classList.remove('added');
          atcBtn.disabled = false;
        }, 2500);
      })
      .catch(function() {
        atcBtn.textContent = 'Fehler – bitte erneut';
        atcBtn.disabled = false;
      });
    });
  }
})();
</script>

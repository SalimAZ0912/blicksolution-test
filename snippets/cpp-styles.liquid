<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  .cpp-wrapper,
  .cpp-features {
    font-family: 'Montserrat', sans-serif;
  }

  .cpp-outer {
    max-width: fit-content;
    margin: 48px auto;
    padding: 0 24px;
  }

  .cpp-wrapper {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 50px;
    align-items: center;
  }

  /* ── GALLERY (Thumbs + Hauptbild) ── */
  .cpp-gallery {
    display: flex;
    flex-direction: row;
    gap: 18px;
    align-items: flex-start;
    align-items: center;
  }

  /* ── THUMBNAILS ── */
  .cpp-thumbs {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cpp-thumb {
    width: 100px;
    height: 100px;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s ease;
    background: #f5f5f5;
  }

  .cpp-thumb.is-active {
    display: none;
  }

  .cpp-thumb:hover {
    border-color: #2563eb;
  }

  .cpp-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── MAIN IMAGE ── */
  .cpp-main-wrap {
    width: 480px;
    height: 480px;
  }

  .cpp-main-img {
    border-radius: 5px;
    overflow: hidden;
    background: #f3f3f3;
    aspect-ratio: 1 / 1;
    width: 480px;
    height: 480px;
  }

  .cpp-main-img img {
    width: 480px;
    height: 480px;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s ease;
  }

  .cpp-arrows {
    display: flex;
    justify-content: center;
    gap: 16px;
  }

  .cpp-arrow {
    background: none;
    border: none;
    cursor: pointer;
    outline: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 10px;
  }

  .cpp-arrow img {
    width: 15px;
    height: 15px;
    display: block;
  }

  .cpp-prev img {
    transform: scaleX(-1);
  }

  .cpp-arrow:disabled img {
    opacity: 0.25;
  }

  .cpp-arrow:disabled {
    cursor: default;
  }

  /* ── INFO CARD ── */
  .cpp-info-card {
    width: 100%;
    background: #ffffff 0% 0% no-repeat padding-box;
    box-shadow: 0px 3px 20px #00000029;
    border: 1px solid #d5d5d5;
    border-radius: 5px;
    padding: 18px 28px;
    display: flex;
    flex-direction: column;
  }

  .cpp-product-title {
    margin-bottom: 12px;
    font: normal normal 600 25px/30px Montserrat;
    letter-spacing: 0px;
    color: #000000;
  }

  .cpp-product-type {
    text-align: left;
    font: normal normal 500 18px/22px Montserrat;
    letter-spacing: 0px;
    color: #000000;
    margin-top: 0;
  }

  .cpp-price {
    display: flex;
    align-items: baseline;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }

  .cpp-price-compare {
    text-align: left;
    text-decoration: line-through;
    font: normal normal 600 18px/22px Montserrat;
    letter-spacing: 0px;
    color: #000000;
    margin-right: 20px;
  }

  .cpp-price-sale {
    text-align: left;
    font: normal normal 600 18px/22px Montserrat;
    letter-spacing: 0px;
    color: #1f47ff;
    margin-right: 6px;
  }

  .cpp-price-tax {
    text-align: left;
    font: normal normal 500 10px/13px Montserrat;
    letter-spacing: 0px;
    color: #000000;
  }

  .cpp-availability {
    text-align: left;
    font: normal normal 500 15px/19px Montserrat;
    letter-spacing: 0px;
    color: #25a525;
    margin-bottom: 37px;
    display: flex;
    align-items: center;
  }

  .cpp-dot {
    width: 15px;
    height: 15px;
    border-radius: 50%;
    display: inline-block;
    margin-right: 10px;
  }

  .cpp-dot--green {
    background: #25a525;
  }
  .cpp-dot--red {
    background: #dc2626;
  }

  /* ── ATC BUTTON ── */
  .cpp-atc-btn {
    font: normal normal 600 18px/22px Montserrat;
    color: #ffffff;
    width: 424px;
    height: 52px;
    background: #1f47ff;
    border-radius: 3px;
    border: none;
  }

  .cpp-atc-btn:hover {
    background: #1d4ed8;
    box-shadow: 0 4px 16px rgba(37, 99, 235, 0.35);
  }

  .cpp-atc-btn:active {
    transform: scale(0.98);
  }
  .cpp-atc-btn:disabled {
    background: #9ca3af;
    cursor: not-allowed;
    box-shadow: none;
  }

  .cpp-atc-btn.added {
    background: #16a34a;
  }

  /* ── FEATURES ── */
  .cpp-features {
    display: grid;
    grid-template-columns: auto;
    grid-auto-flow: column;
    margin-top: 40px;
    padding-top: 40px;
    justify-content: space-between;
  }

  .cpp-feature-item {
    display: flex;
    align-items: center;
    gap: 17px;
  }

  .cpp-feature-icon {
    flex-shrink: 0;
    color: #333;
  }

  .cpp-feature-icon svg {
    width: 48px;
    height: 48px;
  }

  .cpp-feature-text {
    display: flex;
    flex-direction: column;
  }

  .cpp-feature-text strong {
    text-align: left;
    font: normal normal 500 18px/22px Montserrat;
    letter-spacing: 0px;
    margin-bottom: 5px;
    color: #000000;
  }

  .cpp-feature-text span {
    text-align: left;
    font: normal normal normal 18px/22px Montserrat;
    letter-spacing: 0px;
    color: #383838;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 960px) {
    .cpp-wrapper {
      grid-template-columns: 75px 1fr;
      grid-template-rows: auto auto;
    }
    .cpp-info-card {
      grid-column: 1 / -1;
    }
    .cpp-features {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .cpp-wrapper {
      grid-template-columns: 1fr;
    }
    .cpp-thumbs {
      flex-direction: row;
      overflow-x: auto;
      padding-bottom: 4px;
    }
    .cpp-thumb {
      min-width: 70px;
    }
    .cpp-features {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="cpp-feature-item" {{ block.shopify_attributes }}>
  <div class="cpp-feature-icon">
    <img src="{{ 'feature-image.png' | asset_url }}" alt="" width="48" height="48" loading="lazy">
  </div>
  <div class="cpp-feature-text">
    <strong>{{ block.settings.title | default: '100% Qualität' }}</strong>
    <span>{{ block.settings.text | default: 'Dank weichem Silikon' }}</span>
  </div>
</div>
